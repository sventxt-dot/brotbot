# ── Supabase (self-hosted via Coolify) ────────────────────────────────────
SUPABASE_URL=https://supabase.yourdomain.de
# Use the service_role key for migration (write access).
# Use the anon key in the frontend (read-only, safe to expose).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ── OpenAI (embeddings only — text-embedding-3-large) ─────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Anthropic (chat model) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Keep model name configurable — upgrade without code changes.
# claude-haiku-4-5 is the default (cost-optimised for FAQ-style RAG).
ANTHROPIC_MODEL=claude-haiku-4-5

# ── RAG pipeline tuning ───────────────────────────────────────────────────
# Number of top-K documents returned per query (tune iteratively)
RAG_MATCH_COUNT=7
